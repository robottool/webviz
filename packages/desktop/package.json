{
  "name": "@webviz/desktop",
  "version": "0.1.0",
  "description": "WebViz desktop app (Electron): runs the hub in-process behind a native window.",
  "private": true,
  "author": "WebViz",
  "main": "build/main.cjs",
  "scripts": {
    "bundle": "node esbuild.mjs",
    "typecheck": "tsc -p tsconfig.json",
    "start": "pnpm run bundle && electron .",
    "dist": "pnpm run bundle && electron-builder",
    "dist:linux": "pnpm run bundle && electron-builder --linux",
    "dist:win": "pnpm run bundle && electron-builder --win"
  },
  "devDependencies": {
    "@webviz/hub": "workspace:*",
    "@webviz/protocol": "workspace:*",
    "@types/node": "^20.14.0",
    "electron": "^31.7.7",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.2",
    "typescript": "^5.5.4"
  },
  "build": {
    "appId": "dev.webviz.app",
    "productName": "WebViz",
    "directories": { "output": "release" },
    "files": ["build/**/*"],
    "extraResources": [
      { "from": "../app/dist", "to": "app-dist" }
    ],
    "linux": {
      "target": ["AppImage"],
      "category": "Development"
    },
    "win": {
      "target": ["nsis"]
    }
  }
}
