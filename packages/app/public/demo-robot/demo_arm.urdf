<?xml version="1.0"?>
<!--
  WebViz demo robot: a 4-DOF articulated arm built from primitive geometry
  (cylinders + boxes), so it needs no external mesh files and loads instantly.
  Used by the RobotModel Properties "load demo robot" button to showcase URDF
  loading + manual joint sliders without any hub connection or file upload.
-->
<robot name="demo_arm">
  <material name="steel"><color rgba="0.55 0.60 0.66 1"/></material>
  <material name="accent"><color rgba="0.20 0.60 0.90 1"/></material>
  <material name="tip"><color rgba="0.95 0.55 0.20 1"/></material>

  <!-- Fixed base -->
  <link name="base_link">
    <visual>
      <geometry><cylinder radius="0.12" length="0.08"/></geometry>
      <material name="steel"/>
    </visual>
  </link>

  <!-- Shoulder: rotates the whole arm about the vertical axis -->
  <link name="shoulder_link">
    <visual>
      <origin xyz="0 0 0.10"/>
      <geometry><box size="0.10 0.10 0.20"/></geometry>
      <material name="accent"/>
    </visual>
  </link>
  <joint name="shoulder_pan" type="revolute">
    <parent link="base_link"/>
    <child link="shoulder_link"/>
    <origin xyz="0 0 0.04"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="10" velocity="1"/>
  </joint>

  <!-- Upper arm: lifts -->
  <link name="upper_arm_link">
    <visual>
      <origin xyz="0 0 0.15"/>
      <geometry><box size="0.08 0.08 0.30"/></geometry>
      <material name="steel"/>
    </visual>
  </link>
  <joint name="shoulder_lift" type="revolute">
    <parent link="shoulder_link"/>
    <child link="upper_arm_link"/>
    <origin xyz="0 0 0.20"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="2.0" effort="10" velocity="1"/>
  </joint>

  <!-- Forearm: elbow -->
  <link name="forearm_link">
    <visual>
      <origin xyz="0 0 0.125"/>
      <geometry><box size="0.07 0.07 0.25"/></geometry>
      <material name="accent"/>
    </visual>
  </link>
  <joint name="elbow" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="forearm_link"/>
    <origin xyz="0 0 0.30"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.6" upper="2.6" effort="10" velocity="1"/>
  </joint>

  <!-- Wrist + tool tip -->
  <link name="wrist_link">
    <visual>
      <origin xyz="0 0 0.06"/>
      <geometry><box size="0.06 0.06 0.12"/></geometry>
      <material name="steel"/>
    </visual>
    <visual>
      <origin xyz="0 0 0.135"/>
      <geometry><cylinder radius="0.035" length="0.05"/></geometry>
      <material name="tip"/>
    </visual>
  </link>
  <joint name="wrist" type="revolute">
    <parent link="forearm_link"/>
    <child link="wrist_link"/>
    <origin xyz="0 0 0.25"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.1416" upper="3.1416" effort="10" velocity="1"/>
  </joint>
</robot>
